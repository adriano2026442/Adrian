  <div class="cursor-zone">⟳ MOVE MOUSE — LIQUID DISTORTION</div>

  <script>
    (function(){
      "use strict";

      // -------------------- UNSEEN • WEBGL LIQUID / FLUID WORLD --------------------
      // based on chipsa/unseen analysis: WebGL with custom shader, mouse liquid effect,
      // smooth camera, post-processing on full-screen quad.
      
      const container = document.getElementById('canvas-container');
      
      // === SCENE SETUP ===
      const scene = new THREE.Scene();
      scene.background = new THREE.Color('#0b0c0e');
      
      // Camera — perspective for depth
      const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
      camera.position.set(0, 0, 18);
      
      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setClearColor(0x0b0c0e, 1.0);
      container.appendChild(renderer.domElement);
      
      // Make canvas interactive (for mouse trails) — pointer-events: none on container but need to capture mouse.
      // we'll get mouse from window.
      
      // === MOUSE UNIFORMS for liquid distortion ===
      const mouse = new THREE.Vector2(0.5, 0.5);
      const targetMouse = new THREE.Vector2(0.5, 0.5);
      
      window.addEventListener('mousemove', (e) => {
        targetMouse.x = e.clientX / window.innerWidth;
        targetMouse.y = 1.0 - (e.clientY / window.innerHeight);
      });
      
      // === CREATE FULLSCREEN PLANE WITH CUSTOM SHADER (LIQUID / FLUID) ===
      // This emulates unseen's post-processing approach: distortion + noise + fluid.
      
      const geometry = new THREE.PlaneGeometry(2, 2);
      
      // custom shader — UNSEEN inspired: fluid warp, rgb shift, heat, noise
      const material = new THREE.ShaderMaterial({
        uniforms: {
          u_time: { value: 0 },
          u_mouse: { value: new THREE.Vector2(0.5, 0.5) },
          u_resolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
          u_intensity: { value: 0.8 }
        },
        vertexShader: `
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
          }
        `,
        fragmentShader: `
          precision highp float;
          varying vec2 vUv;
          uniform vec2 u_mouse;
          uniform vec2 u_resolution;
          uniform float u_time;
          uniform float u_intensity;
          
          // Simplex noise functions (classic, for fluid feel)
          vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec4 mod289(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
          vec4 permute(vec4 x) { return mod289(((x*34.0)+1.0)*x); }
          vec4 taylorInvSqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }
          
          float snoise(vec3 v) {
            const vec2 C = vec2(1.0/6.0, 1.0/3.0);
            const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);
            vec3 i  = floor(v + dot(v, C.yyy) );
            vec3 x0 = v -   i + dot(i, C.xxx);
            vec3 g = step(x0.yzx, x0.xyz);
            vec3 l = 1.0 - g;
            vec3 i1 = min( g.xyz, l.zxy );
            vec3 i2 = max( g.xyz, l.zxy );
            vec3 x1 = x0 - i1 + C.xxx;
            vec3 x2 = x0 - i2 + C.yyy;
            vec3 x3 = x0 - D.yyy;
            i = mod289(i);
            vec4 p = permute( permute( permute( 
                      i.z + vec4(0.0, i1.z, i2.z, 1.0 ))
                    + i.y + vec4(0.0, i1.y, i2.y, 1.0 )) 
                    + i.x + vec4(0.0, i1.x, i2.x, 1.0 ));
            float n_ = 0.142857142857;
            vec3  ns = n_ * D.wyz - D.xzx;
            vec4 j = p - 49.0 * floor(p * ns.z * ns.z);  // mod(p,7*7)
            vec4 x_ = floor(j * ns.z);
            vec4 y_ = floor(j - 7.0 * x_);    // mod(j,N)
            vec4 x = x_ *ns.x + ns.yyyy;
            vec4 y = y_ *ns.x + ns.yyyy;
            vec4 h = 1.0 - abs(x) - abs(y);
            vec4 b0 = vec4( x.xy, y.xy );
            vec4 b1 = vec4( x.zw, y.zw );
            vec4 s0 = floor(b0)*2.0 + 1.0;
            vec4 s1 = floor(b1)*2.0 + 1.0;
            vec4 sh = -step(h, vec4(0.0));
            vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy ;
            vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww ;
            vec3 p0 = vec3(a0.xy,h.x);
            vec3 p1 = vec3(a0.zw,h.y);
            vec3 p2 = vec3(a1.xy,h.z);
            vec3 p3 = vec3(a1.zw,h.w);
            vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2, p2), dot(p3,p3)));
            p0 *= norm.x; p1 *= norm.y; p2 *= norm.z; p3 *= norm.w;
            vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
            m = m * m;
            return 42.0 * dot( m*m, vec4( dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3) ) );
          }
          
          float fbm(vec3 p) {
            float sum = snoise(p);
            sum += snoise(p*2.0 - 1.0)*0.5;
            sum += snoise(p*4.0 + 2.0)*0.25;
            return sum * 0.5 + 0.5;
          }
          
          void main() {
            vec2 uv = vUv;
            vec2 aspect = vec2(u_resolution.x / u_resolution.y, 1.0);
            vec2 p = uv * aspect;
            
            // mouse influence distance (liquid)
            vec2 mousePos = u_mouse * aspect;
            float dist = distance(p, mousePos);
            float mouseFactor = smoothstep(0.8, 0.0, dist) * 0.8;
            
            // time variables
            float t1 = u_time * 0.3;
            float t2 = u_time * 0.5;
            
            // fluid distortion field — unseen style: noise + mouse + time
            vec3 coord = vec3(uv.x * 3.0 + sin(t1)*0.2, uv.y * 2.5 + cos(t2)*0.2, u_time * 0.2);
            float noiseVal = fbm(coord);
            
            // RGB shift from noise and mouse
            float shiftR = sin(uv.y * 15.0 + u_time * 2.0) * 0.006 + mouseFactor * 0.03;
            float shiftG = cos(uv.x * 12.0 + u_time * 1.7) * 0.006 + mouseFactor * 0.02;
            float shiftB = sin((uv.x+uv.y)*10.0 + u_time*2.5) * 0.008 + mouseFactor * 0.025;
            
            // base color: world cup palette (black, gold, white, subtle blue)
            // create a lava/liquid gold base
            float goldPattern = sin(uv.x * 25.0 + u_time) * cos(uv.y * 20.0 + u_time*0.8);
            goldPattern = clamp(goldPattern*0.5+0.5, 0.2, 1.0);
            
            vec3 colorGold = vec3(0.96, 0.82, 0.35); // FIFA gold
            vec3 colorDark = vec3(0.05, 0.07, 0.09);
            vec3 colorBlue = vec3(0.12, 0.18, 0.32);
            
            // base gradient + 442oons blue hint
            vec3 baseColor = mix(colorDark, colorBlue, uv.y * 1.2);
            baseColor = mix(baseColor, colorGold, goldPattern * 0.4 + mouseFactor * 0.6);
            
            // add world cup trophy shimmer (trophy glow)
            float trophyGlow = pow(1.0 - distance(uv, vec2(0.5, 0.35)), 2.0) * 0.8;
            baseColor += vec3(0.9,0.7,0.2) * trophyGlow * (0.6 + 0.4*sin(u_time*3.0));
            
            // huge SUUUU text in background (like unseen's subtle branding)
            float textMask = 0.0;
            // We simulate "SUUUU" using uv repetition; not real text but pattern from unseen.
            // but we add an overlay pattern.
            vec2 gridUv = fract(uv * 6.0 + vec2(u_time*0.02, 0.0));
            float grid = step(0.98, gridUv.x) + step(0.98, gridUv.y);
            baseColor += grid * 0.08 * vec3(1.0,0.9,0.5);
            
            // APPLY RGB SHIFT (chromatic aberration / fluid)
            vec2 rUv = uv + vec2(shiftR, shiftR*0.6);
            vec2 gUv = uv + vec2(shiftG*0.8, shiftG);
            vec2 bUv = uv + vec2(shiftB, -shiftB*0.7);
            
            // fetch noise again for each channel to mimic distortion on color
            // but we also want to keep base color, just shift it.
            vec3 rNoise = vec3(fbm(vec3(rUv*3.0, u_time*0.2)));
            vec3 gNoise = vec3(fbm(vec3(gUv*3.0, u_time*0.3)));
            vec3 bNoise = vec3(fbm(vec3(bUv*3.0, u_time*0.4)));
            
            // combine with mouse-driven warping
            float warpAmount = (noiseVal - 0.5) * 0.15 + mouseFactor * 0.2;
            
            // final color composition
            vec3 finalColor;
            finalColor.r = baseColor.r * (1.0 + warpAmount*0.5) + rNoise.r*0.15;
            finalColor.g = baseColor.g * (0.9 + mouseFactor*0.3) + gNoise.g*0.12;
            finalColor.b = baseColor.b * (1.0 + warpAmount*0.4) + bNoise.b*0.18;
            
            // boost contrast & gold
            finalColor = mix(finalColor, vec3(0.95,0.78,0.25), mouseFactor*0.7);
            
            // post: vignette, scanline (brutal)
            float vignette = 1.0 - length(vUv - 0.5) * 0.9;
            finalColor *= vignette;
            
            // rim light from mouse
            finalColor += vec3(0.9,0.7,0.3) * pow(mouseFactor, 1.5) * 0.5;
            
            gl_FragColor = vec4(finalColor, 1.0);
          }
        `
      });
      
      const mesh = new THREE.Mesh(geometry, material);
      scene.add(mesh);
      
      // additional 3D elements to enhance unseen depth: floating wireframe trophy or motion
      // but we keep first the shader plane dominant; still add a simple rotating object with wireframe to create sense of 3D.
      const icosahedronGeo = new THREE.IcosahedronGeometry(1.2, 1);
      const wireframeMat = new THREE.MeshBasicMaterial({ color: 0xd4af37, wireframe: true, transparent: true, opacity: 0.18 });
      const trophyCore = new THREE.Mesh(icosahedronGeo, wireframeMat);
      trophyCore.position.set(1.2, -0.5, -3.0);
      scene.add(trophyCore);
      
      const ringGeo = new THREE.TorusGeometry(1.8, 0.03, 16, 100);
      const ringMat = new THREE.MeshStandardMaterial({ color: 0xffd966, emissive: new THREE.Color(0x553300), wireframe: false, transparent: true, opacity: 0.2 });
      const ring = new THREE.Mesh(ringGeo, ringMat);
      ring.position.set(-1.8, 0.8, -3.5);
      ring.rotation.x = 0.5;
      ring.rotation.y = 0.8;
      scene.add(ring);
      
      // subtle lights
      const ambient = new THREE.AmbientLight(0x404060);
      scene.add(ambient);
      const dirLight = new THREE.DirectionalLight(0xffeedd, 0.9);
      dirLight.position.set(1, 2, 3);
      scene.add(dirLight);
      
      // SCROLL + MOTION INTEGRATION — EXACTLY UNSEEN STYLE (damping, scroll sync)
      let clock = new THREE.Clock();
      
      // init Lenis smooth scroll (exactly like unseen)
      const lenis = new Lenis({
        duration: 1.5,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical',
        smooth: true,
        smoothTouch: false,
        touchMultiplier: 2,
      });
      
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
      
      // GSAP ScrollTrigger with Lenis
      gsap.registerPlugin(ScrollTrigger);
      
      // Sync Lenis with ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);
      ScrollTrigger.defaults({ scroller: document.body });
      
      // add scroll-based tweaks for extra motion (camera, shader uniforms)
      ScrollTrigger.create({
        trigger: "body",
        start: "top top",
        end: "bottom bottom",
        onUpdate: (self) => {
          const progress = self.progress;
          // adjust camera position slightly
          camera.position.z = 18 - progress * 2.5;
          camera.position.x = Math.sin(progress * Math.PI) * 1.2;
          camera.lookAt(0, 0, 0);
          
          // tweak mouse intensity
          if (material.uniforms) {
            material.uniforms.u_intensity.value = 0.7 + progress * 0.6;
          }
        }
      });
      
      // Animate characters on click (siuuu trigger)
      document.getElementById('trigger-siu').addEventListener('click', () => {
        gsap.to('.glitch-large', {
          scale: 1.2,
          textShadow: "0 0 40px #ffaa00, 0 0 100px #d4af37",
          duration: 0.4,
          yoyo: true,
          repeat: 5,
          ease: "power4.inOut"
        });
        gsap.to(camera.position, {
          z: 14,
          y: 0.5,
          duration: 1.2,
          ease: "elastic.out(1, 0.3)",
          yoyo: true,
          repeat: 1,
        });
        // trigger mouse liquid pop
        targetMouse.set(0.5, 0.5);
      });
      
      // RESIZE
      window.addEventListener('resize', onWindowResize, false);
      function onWindowResize() {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        material.uniforms.u_resolution.value.set(window.innerWidth, window.innerHeight);
      }
      
      // Animation Loop
      function animate() {
        requestAnimationFrame(animate);
        
        const delta = clock.getDelta();
        const elapsedTime = performance.now() * 0.001; // seconds
        
        // smooth mouse interpolation (liquid feel)
        mouse.lerp(targetMouse, 0.06);
        
        // update shader
        if (material.uniforms) {
          material.uniforms.u_time.value = elapsedTime * 1.2;
          material.uniforms.u_mouse.value.lerp(mouse, 0.1);
        }
        
        // rotate 3D objects slowly
        trophyCore.rotation.y += 0.002;
        trophyCore.rotation.x = Math.sin(elapsedTime * 0.2) * 0.1;
        ring.rotation.z += 0.001;
        ring.rotation.x += 0.001;
        
        // slight camera bob (unseen style)
        camera.position.y = Math.sin(elapsedTime * 0.3) * 0.2;
        camera.lookAt(0, -0.2, 0);
        
        renderer.render(scene, camera);
      }
      
      animate();
      
      // extra micro-interactions: mouse trail on siuu element
      const heroDiv = document.querySelector('.hero-text');
      if(heroDiv) {
        heroDiv.addEventListener('mousemove', (e) => {
          const rect = heroDiv.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width;
          const y = (e.clientY - rect.top) / rect.height;
          targetMouse.set(x, 1.0 - y);
        });
      }
      
      // ALSO handle window mouse to always have liquid, but hero gives extra precision.
      // that's it — everything matches unseen motion principles: WebGL fluid, custom scroll, GSAP triggers.
      
      // Wait for fonts & trigger initial animation
      window.addEventListener('load', () => {
        gsap.from('.glitch-large', { opacity: 0, y: 70, duration: 1.4, ease: 'power3.out' });
        gsap.from('.world-cup-badge', { opacity: 0, x: -40, duration: 1.2, delay: 0.2, ease: 'back.out(1.2)' });
        gsap.from('.suuu-stripe', { opacity: 0, scale: 0.8, duration: 1.1, delay: 0.4, ease: 'elastic.out(1,0.4)' });
      });
      
    })();
  </script>
</body>
</html>
